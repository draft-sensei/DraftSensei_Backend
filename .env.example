# DraftSensei Backend Configuration

# ===== DATABASE (Neon PostgreSQL) =====
DATABASE_URL=postgresql://user:password@ep-xxxx-region.neon.tech/neondb?sslmode=require&channel_binding=require

# ===== APPLICATION =====
ENV=development
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ===== LOGGING =====
LOG_LEVEL=INFO

# ===== CORS (Frontend URL) =====
FRONTEND_URL=http://localhost:3000
